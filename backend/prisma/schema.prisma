generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  email        String
  phone        String
  createdAt    DateTime @default(now())

  roles     UserRole[]
  sessions  Session[]
  store     Store?
  wallet    Wallet?
  addresses Address[]
  cart      Cart?
}

model UserRole {
  id       String @id @default(uuid())
  userId   String
  roleType String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleType])
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  activeRole String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppReview {
  id           String   @id @default(uuid())
  userId       String?
  reviewerName String
  rating       Int
  comment      String
  createdAt    DateTime @default(now())
}

model Store {
  id           String   @id @default(uuid())
  sellerUserId String   @unique
  storeName    String   @unique
  description  String?
  createdAt    DateTime @default(now())

  seller   User      @relation(fields: [sellerUserId], references: [id], onDelete: Cascade)
  products Product[]
  carts    Cart[]
}

model Product {
  id          String   @id @default(uuid())
  storeId     String
  name        String
  description String?
  price       Int
  stock       Int
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())

  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cartItems CartItem[]
}

model Wallet {
  id          String   @id @default(uuid())
  buyerUserId String   @unique
  balance     Int      @default(0)
  updatedAt   DateTime @updatedAt

  buyer        User                @relation(fields: [buyerUserId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id        String   @id @default(uuid())
  walletId  String
  orderId   String?
  type      String
  amount    Int
  createdAt DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)
}

model Address {
  id            String   @id @default(uuid())
  buyerUserId   String
  label         String
  recipientName String
  phone         String
  fullAddress   String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  buyer User @relation(fields: [buyerUserId], references: [id], onDelete: Cascade)
}

model Cart {
  id          String   @id @default(uuid())
  buyerUserId String   @unique
  storeId     String?
  updatedAt   DateTime @updatedAt

  buyer User       @relation(fields: [buyerUserId], references: [id], onDelete: Cascade)
  store Store?     @relation(fields: [storeId], references: [id], onDelete: SetNull)
  items CartItem[]
}

model CartItem {
  id        String @id @default(uuid())
  cartId    String
  productId String
  quantity  Int

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}
